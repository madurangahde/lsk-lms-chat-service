PORT=8085
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
SOCKET_PATH=/socket.io
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lms_chat?retryWrites=true&w=majority

# Existing LMS APIs
LMS_AUTH_ME_URL=https://your-lms-domain.com/api/auth/me
LMS_USERS_LIST_URL=https://your-lms-domain.com/api/admin/users?page=0&size=10000
LMS_TIMEOUT_MS=5000

# Role mapping from LMS
ADMIN_ROLE_NAMES=ADMIN,SUPER_ADMIN
USER_ROLE_NAMES=USER,STUDENT

# Chat limits
AUTH_CACHE_TTL_SECONDS=60
MAX_MESSAGE_LENGTH=4000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Optional Redis (recommended only if you run multiple chat containers)
USE_REDIS=false
REDIS_URL=redis://localhost:6379
